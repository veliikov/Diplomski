{
  "name": "wallet-toolkit",
  "version": "1.0.0",
  "description": "Lightweight Web3 utilities for wallet addresses, balances, networks, and block explorers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "import": "./dist/wallet-toolkit.browser.js"
    }
  },
  "bin": {
    "wallet-toolkit": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run build:browser",
    "build:browser": "esbuild src/index.ts --bundle --format=esm --platform=browser --outfile=dist/wallet-toolkit.browser.js",
    "build:browser:watch": "esbuild src/index.ts --bundle --format=esm --platform=browser --outfile=dist/wallet-toolkit.browser.js --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "prepublishOnly": "npm run build && npm run test",
    "prepack": "npm run build"
  },
  "keywords": [
    "web3",
    "ethereum",
    "wallet",
    "blockchain",
    "address",
    "explorer",
    "etherscan",
    "sepolia",
    "checksum",
    "eip-55"
  ],
  "author": "Nikola Velikov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veliikov/wallet-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/veliikov/wallet-toolkit/issues"
  },
  "homepage": "https://github.com/veliikov/wallet-toolkit#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  }
}
